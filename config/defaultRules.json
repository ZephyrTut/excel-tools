{
  "appName": "Excel Tools",
  "defaultOutputDir": ".\\output",
  "preserveSheetOrder": true,
  "overwriteIfExists": true,
  "ifExistsStrategy": "timestamp",
  "templateFile": "_default.xlsx",
  "fileName": {
    "source": "splitKey",
    "prefix": "",
    "suffix": "日报表",
    "customName": "",
    "sanitizeWindowsName": true,
    "maxLength": 120
  },
  "split": {
    "skipEmptySplitKey": true,
    "trimSplitKey": true
  },
  "merge": {
    "enabled": false,
    "inputDir": ".\\test",
    "outputName": "合并汇总.xlsx",
    "orderSheetName": "日报",
    "orderColumn": "C",
    "appendUnknownVendorsToEnd": true
  },
  "sheetRules": [
    {
      "enabled": true,
      "sheetName": "日报",
      "headerRows": 3,
      "splitColumn": "C",
      "splitBy": "cellValue",
      "outputSheetName": "日报",
      "skipEmpty": true,
      "removeColumnsByHeader": [],
      "columnAliasMap": {}
    },
    {
      "enabled": true,
      "sheetName": "合格品入库记录",
      "headerRows": 1,
      "splitColumn": "C",
      "splitBy": "cellValue",
      "outputSheetName": "合格品入库记录",
      "skipEmpty": true,
      "removeColumnsByHeader": [],
      "columnAliasMap": {}
    },
    {
      "enabled": true,
      "sheetName": "合格品出库记录",
      "headerRows": 1,
      "splitColumn": "C",
      "splitBy": "cellValue",
      "outputSheetName": "合格品出库记录",
      "skipEmpty": true,
      "removeColumnsByHeader": [],
      "columnAliasMap": {}
    },
    {
      "enabled": true,
      "sheetName": "领跑良品退回",
      "headerRows": 1,
      "splitColumn": "C",
      "splitBy": "cellValue",
      "outputSheetName": "领跑良品退回",
      "skipEmpty": true,
      "removeColumnsByHeader": [],
      "columnAliasMap": {}
    },
    {
      "enabled": true,
      "sheetName": "不良品库存",
      "headerRows": 1,
      "splitColumn": "C",
      "splitBy": "cellValue",
      "outputSheetName": "不良品库存",
      "skipEmpty": true,
      "removeColumnsByHeader": [],
      "columnAliasMap": {}
    }
  ]
}

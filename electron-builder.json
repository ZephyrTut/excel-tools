{
  "appId": "com.excel.tools",
  "productName": "Excel Tools",
  "directories": {
    "output": "dist/installers"
  },
  "asar": false,
  "extraResources": [
    {
      "from": "resources/python",
      "to": "python",
      "filter": ["**/*"]
    }
  ],
  "electronLanguages": [
    "en-US",
    "zh-CN"
  ],
  "publish": {
    "provider": "github",
    "owner": "ZephyrTut",
    "repo": "excel-tools"
  },
  "files": [
    "main/**/*",
    "services/**/*",
    "dist/renderer/**/*",
    "config/**/*",
    "package.json",
    "!main/**/*.test.*",
    "!services/**/*.test.*",
    "!services/**/__pycache__/**",
    "!services/**/*.pyc",
    "!services/send/test_*.py"
  ],
  "win": {
    "icon": "assets/logo.png",
    "artifactName": "Excel-Tools-Setup-v${version}.${ext}",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}

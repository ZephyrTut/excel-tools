{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(git *)",
      "Bash(node -e ' *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)"
    ]
  }
}

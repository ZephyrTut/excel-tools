{
  "name": "excel-tools",
  "version": "0.1.0",
  "description": "Excel automation desktop tools built with Electron + Vue + ExcelJS",
  "main": "main/main.js",
  "author": "excel-tools",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.config.mjs\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build --config vite.config.mjs",
    "build": "npm run build:renderer && electron-builder",
    "start": "cross-env NODE_ENV=production electron .",
    "split:zhejiang": "node scripts/generate-split.js",
    "compare:zhejiang": "node scripts/compare-with-output.js"
  },
  "dependencies": {
    "element-plus": "^2.10.0",
    "exceljs": "^4.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.19",
    "wait-on": "^8.0.1"
  }
}

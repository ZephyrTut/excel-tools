{
  "name": "excel-tools",
  "version": "1.2.10",
  "description": "Excel automation desktop tools built with Electron + Vue + ExcelJS",
  "main": "main/main.js",
  "author": "excel-tools",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"node ./node_modules/vite/bin/vite.js --config vite.config.mjs\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "node scripts/build-renderer.mjs",
    "setup:python": "node scripts/download-python.js",
    "clean": "node scripts/clean.js",
    "build": "pnpm clean && pnpm setup:python && pnpm build:renderer && pnpm exec electron-builder --win",
    "start": "cross-env NODE_ENV=production electron .",
    "split:zhejiang": "node scripts/generate-split.js",
    "compare:zhejiang": "node scripts/compare-with-output.js",
    "merge": "node --max-old-space-size=8192 scripts/generate-merge.js",
    "merge:huzhou": "node scripts/generate-merge.js",
    "compare:merge": "node scripts/compare-merge-output.js",
    "test": "node scripts/run-local-tests.js",
    "test:watch": "node --test --watch main/**/*.test.js services/**/*.test.js",
    "test:vitest": "vitest run --config ./vitest.config.mjs",
    "release": "node scripts/release.js",
    "changelog": "node scripts/generate-changelog.js --write"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "element-plus": "^2.10.0",
    "jsdom": "^29.1.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4",
    "vue": "^3.5.13",
    "wait-on": "^8.0.1",
    "wrangler": "^4.98.0"
  }
}

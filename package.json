{
  "name": "excel-tools",
  "version": "0.3.1",
  "description": "Excel automation desktop tools built with Electron + Vue + ExcelJS",
  "main": "main/main.js",
  "author": "excel-tools",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.config.mjs\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build --config vite.config.mjs",
    "clean": "node scripts/clean.js",
    "build": "npm run clean && npm run build:renderer && npx electron-builder --win",
    "start": "cross-env NODE_ENV=production electron .",
    "split:zhejiang": "node scripts/generate-split.js",
    "compare:zhejiang": "node scripts/compare-with-output.js",
    "merge": "node --max-old-space-size=8192 scripts/generate-merge.js",
    "merge:huzhou": "node scripts/generate-merge.js",
    "compare:merge": "node scripts/compare-merge-output.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "element-plus": "^2.10.0",
    "exceljs": "^4.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  }
}
